<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a3a4a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#2d5a6b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4a90a4;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="water" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4a90a4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6ab0c4;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="800" fill="url(#grad1)"/>

  <!-- Decorative lake shape -->
  <ellipse cx="800" cy="400" rx="250" ry="150" fill="url(#water)" opacity="0.3"/>
  <ellipse cx="400" cy="500" rx="180" ry="100" fill="url(#water)" opacity="0.2"/>

  <!-- Trees silhouette -->
  <g fill="#1a3a4a" opacity="0.4">
    <path d="M100 800 L130 650 L100 680 L130 550 L100 580 L140 450 L80 450 L120 580 L90 550 L120 650 L90 680 L120 800 Z"/>
    <path d="M200 800 L240 600 L200 640 L250 480 L180 480 L230 640 L190 600 L230 800 Z"/>
    <path d="M1050 800 L1090 620 L1050 660 L1100 500 L1030 500 L1080 660 L1040 620 L1080 800 Z"/>
    <path d="M1120 800 L1150 680 L1120 710 L1160 580 L1100 580 L1140 710 L1110 680 L1140 800 Z"/>
  </g>

  <!-- Text -->
  <text x="600" y="380" font-family="Georgia, serif" font-size="48" fill="white" text-anchor="middle" opacity="0.9">Hidden Lakes</text>
  <text x="600" y="430" font-family="Arial, sans-serif" font-size="18" fill="#c9a962" text-anchor="middle" letter-spacing="4">PREMIUM ESTATE LIVING</text>
  <text x="600" y="480" font-family="Arial, sans-serif" font-size="14" fill="white" text-anchor="middle" opacity="0.7">Professional photography coming soon</text>
</svg>
